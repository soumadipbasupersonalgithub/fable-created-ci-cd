  },
  "homepage": "https://github.com/soumadipbasupersonalgithub/fable-created-ci-cd#readme",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  }
}
